{
  "name": "duckdeploy",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "npm run generate && npm run compile:schema && vite",
    "build": "npm run generate && npm run compile:schema && npm run validate:contract && npm run generate:traceability && vite build && npm run verify:shadow",
    "lint": "eslint .",
    "preview": "vite preview",
    "proxy": "node ./server/cdisc-proxy.mjs",
    "generate:api": "orval --config ./orval.config.ts",
    "build:manifest": "node ./scripts/preprocessor.mjs",
    "generate:traceability": "node ./scripts/generate-traceability.mjs",
    "generate": "npm run generate:api && npm run build:manifest && npm run generate:traceability",
    "compile:schema": "node ./scripts/compiler/compile-schema.mjs",
    "verify:shadow": "node ./scripts/verify-shadow-build.mjs",
    "validate:contract": "node ./scripts/validate-contract.mjs",
    "test:fuzz": "node ./scripts/fuzz/run-schemathesis.mjs"
  },
  "dependencies": {
    "@apidevtools/json-schema-ref-parser": "^15.3.5",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mui/icons-material": "^9.0.1",
    "@mui/material": "^9.0.1",
    "@tanstack/react-query": "^5.100.9",
    "@types/js-yaml": "^4.0.9",
    "axios": "^1.16.0",
    "js-yaml": "^4.2.0",
    "lodash": "^4.17.21",
    "react": "^18.3.1",
    "react-admin": "^5.14.6",
    "react-dom": "^18.3.1",
    "@duckdeploy/openapi": "workspace:*"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/lodash": "^4.17.24",
    "@types/node": "^24.12.2",
    "@types/react": "^18.3.28",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.2.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.5.0",
    "openapi-types": "^12.1.3",
    "orval": "^8.18.0",
    "prettier": "^3.8.3",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.2",
    "vite": "^8.0.16"
  },
  "workspaces": [
    "packages/*"
  ]
}