{
  "name": "duckdeploy",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "dev": "npm run generate && npm run compile:schema && vite",
    "typecheck": "tsc -b",
    "build": "npm run lint && npm run typecheck && npm run generate && npm run compile:schema && npm run validate:contract && npm run generate:traceability && npm run docs:build && npm run test && vite build && npm run verify:shadow && npm run scan:a11y && node ./scripts/publish-compliance.mjs",
    "lint:md": "markdownlint \"**/*.md\" --ignore node_modules && find . -name '*.md' -not -path '*/node_modules/*' -not -path '*/dist/*' -exec markdown-link-check -q {} +",
    "lint": "eslint . --max-warnings 0 && npm run lint:md",
    "preview": "vite preview",
    "proxy": "node ./server/cdisc-proxy.mjs",
    "prune:api": "node ./scripts/prune-api.mjs",
    "generate:api": "orval --config ./orval.config.ts",
    "build:manifest": "node ./scripts/preprocessor.mjs",
    "build:env": "node ./scripts/config/build.mjs",
    "generate:traceability": "node ./scripts/generate-traceability.mjs",
    "generate": "npm run build:env && npm run prune:api && npm run generate:api && npm run build:manifest && npm run generate:traceability",
    "compile:schema": "node ./scripts/compiler/compile-schema.mjs",
    "verify:shadow": "node ./scripts/verify-shadow-build.mjs",
    "validate:contract": "node ./scripts/validate-contract.mjs",
    "test:fuzz": "node ./scripts/fuzz/run-schemathesis.mjs",
    "test": "vitest run --reporter=default --reporter=junit --outputFile.junit=junit.xml",
    "test:watch": "vitest",
    "scan:a11y": "node ./scripts/accessibility-scan.mjs",
    "analyze:structure": "knip --include files,exports,duplicates,dependencies,types",
    "docs:build": "typedoc",
    "prepare": "husky"
  },
  "dependencies": {
    "@apidevtools/json-schema-ref-parser": "^15.3.5",
    "@duckdeploy/openapi": "workspace:*",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mui/icons-material": "^9.0.1",
    "@mui/material": "^9.0.1",
    "@tanstack/react-query": "^5.100.9",
    "ajv": "^8.20.0",
    "axios": "^1.16.0",
    "react": "^18.3.1",
    "react-admin": "^5.14.6",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@axe-core/puppeteer": "^4.12.1",
    "@eslint/js": "^10.0.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest-axe": "^3.5.9",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^24.12.2",
    "@types/react": "^18.3.28",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.2.1",
    "eslint-plugin-jsdoc": "^63.0.10",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.5.0",
    "husky": "^9.1.7",
    "jest-axe": "^10.0.0",
    "js-yaml": "^4.2.0",
    "jsdom": "^29.1.1",
    "knip": "^6.24.0",
    "lint-staged": "^17.0.8",
    "markdown-link-check": "^3.14.2",
    "markdownlint-cli": "^0.49.1",
    "openapi-types": "^12.1.3",
    "orval": "^8.18.0",
    "prettier": "^3.8.3",
    "puppeteer": "^25.3.0",
    "typedoc": "^0.28.19",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.2",
    "vite": "^8.0.16",
    "vitest": "^4.1.9"
  },
  "overrides": {
    "eslint-plugin-jsx-a11y": {
      "eslint": "^10.2.1"
    }
  },
  "workspaces": [
    "packages/*"
  ],
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "eslint --fix"
    ],
    "*.md": [
      "markdownlint --fix",
      "markdown-link-check -q"
    ]
  }
}
