# Environment Configuration Example
# This file is automatically generated from config.schema.json.

# Port for the proxy server to listen on.
# Type: number
PORT=8787

# Primary API key for CDISC Library.
# Type: string (Required)
CDISC_PRIMARY_KEY=

# Secondary API key for CDISC Library.
# Type: string
CDISC_SECONDARY_KEY=

# Path prefix for the CDISC proxy.
# Type: string
CDISC_PROXY_PREFIX=/api/cdisc

# Maximum allowed request body size in bytes.
# Type: number
CDISC_PROXY_MAX_BODY_BYTES=1048576

# Upstream request timeout in milliseconds.
# Type: number
CDISC_PROXY_TIMEOUT_MS=15000

# Header name for trusted ingress assertion.
# Type: string
CDISC_TRUSTED_INGRESS_HEADER_NAME=

# Header value for trusted ingress assertion.
# Type: string
CDISC_TRUSTED_INGRESS_HEADER_VALUE=

# Comma-separated list of allowed CORS origins.
# Type: string
CDISC_ALLOWED_ORIGINS=http://localhost:5173, http://127.0.0.1:5173

# Comma-separated list of additional allowed headers.
# Type: string
PROXY_ALLOWED_HEADERS=

# Set to true to allow unrestricted CORS access.
# Type: boolean
CDISC_ALLOW_UNTRUSTED_ORIGINS=false

# The base URL of the upstream CDISC API.
# Type: string
CDISC_UPSTREAM_BASE_URL=https://api.library.cdisc.org/api

# Header to read total count from (frontend).
# Type: string
VITE_TOTAL_COUNT_HEADER=

# Deployed CDISC proxy base URL for frontend.
# Type: string
VITE_API_BASE_URL=

# Base URL for fuzz testing.
# Type: string
SCHEMATHESIS_BASE_URL=

# Max examples per endpoint for fuzz testing.
# Type: number
SCHEMATHESIS_MAX_EXAMPLES=1000

# Fail fuzz testing if Schemathesis returns non-zero.
# Type: boolean
SCHEMATHESIS_STRICT=true

